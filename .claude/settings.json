{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_project": "yesid.dev — workflow-overlord 2.0 (post-retrofit 2026-05-13)",
  "hooks": {
    "SessionStart": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "bash .claude/hooks/session-start.sh" }] }
    ],
    "Stop": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "bash .claude/hooks/session-end.sh" }] }
    ],
    "PreToolUse": [
      { "matcher": "mcp__.*__API-.*",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/pretool-check-notion-config.sh" },
          { "type": "command", "command": "bash .claude/hooks/pretool-check-notion-edit.sh" }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["overlord-bridge", "notionhq", "yesid-cms-prod"]
}
