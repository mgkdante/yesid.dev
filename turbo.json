{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".svelte-kit/**", ".vercel/**", "dist/**"],
			"inputs": ["$TURBO_DEFAULT$", "!**/.env.local", "!**/.env.*.local"]
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"check": {
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
