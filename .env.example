# yesid.dev-cms — Directus environment variables
#
# Copy to `.env` locally; paste each block into Railway Dashboard → Variables in prod.
# Never commit a filled .env — it's gitignored.
#
# Spec: https://github.com/mgkdante/yesid.dev/tree/main/docs/slices/slice-18
# Target version: directus/directus:11.17.3 (pin; don't float `latest`).

# --- Directus core (required) ----------------------------------------------

# Secrets — generate once per environment, never rotate casually.
#   KEY:    openssl rand -hex 16   (16-byte hex, used for internal JWT signing)
#   SECRET: openssl rand -hex 32   (32-byte hex, used for access-token signing)
KEY=
SECRET=

# Public URL — where Directus serves its admin + API. Set to the final URL once
# DNS flips; during Railway provisioning use the temporary Railway domain.
PUBLIC_URL=https://cms.yesid.dev

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# --- Admin bootstrap (delete after first successful login) -----------------
#
# On first boot with an empty `directus_users` table, Directus creates one
# admin from these vars. Rotate the password via the admin UI immediately,
# then DELETE both vars from Railway — they're a bootstrap, not a standing
# credential.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Database (Neon Postgres — BYO, preserved across migration) ------------
#
# Use the POOLED connection string from Neon for Directus (unpooled is for
# scripts / migrations; Directus handles its own connection pool).
# Format: postgres://user:pass@ep-xxxx-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DB_CLIENT=pg
DB_CONNECTION_STRING=
DB_SSL__REJECT_UNAUTHORIZED=true

# --- Storage (Cloudflare R2 via built-in s3 driver) ------------------------
#
# R2 credentials from Cloudflare Dashboard → R2 → Manage API Tokens.
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com (no bucket in URL).
# Region: always `auto` for R2.
# Force path style: required for R2 (bucket comes after endpoint, not as subdomain).
STORAGE_LOCATIONS=s3
STORAGE_S3_DRIVER=s3
STORAGE_S3_KEY=
STORAGE_S3_SECRET=
STORAGE_S3_BUCKET=yesid-dev-cms
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=auto
STORAGE_S3_FORCE_PATH_STYLE=true

# --- Cache (Redis — improves API throughput; Railway template provisions) --
#
# If Railway template includes a Redis plugin, CACHE_REDIS is auto-injected.
# Otherwise set manually or disable (CACHE_ENABLED=false).
CACHE_ENABLED=true
CACHE_STORE=redis
CACHE_REDIS=
CACHE_AUTO_PURGE=true
CACHE_TTL=5m

# --- Email (Resend via SMTP — DKIM + SPF already set on domain) ------------
#
# Resend API key from resend.com/api-keys — use the SAME key the prior Payload
# install used (already configured). SMTP user is literally the string "resend".
EMAIL_FROM=no-reply@yesid.dev
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=smtp.resend.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=resend
EMAIL_SMTP_PASSWORD=

# --- CORS (allow yesid.dev consumer + Vercel preview deployments) ----------
CORS_ENABLED=true
CORS_ORIGIN=https://yesid.dev,https://*.vercel.app
CORS_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_CREDENTIALS=true

# --- Rate limiter (default disabled on self-host) ---------------------------
RATE_LIMITER_ENABLED=false

# --- MCP server (native since v11.13 — GA Nov 2025) ------------------------
#
# Enables the /mcp endpoint. Create a dedicated `ai-editor` role in Directus
# and issue it a static access token for Claude Code / Desktop / other MCP clients.
# Role scope: content collections only — NOT directus_users, directus_settings, etc.
MCP_ENABLED=true
