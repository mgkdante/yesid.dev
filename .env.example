# yesid.dev root dotenv reference file.
#
# Copy this file to `.env`, replace every placeholder with a copied
# 1Password `op://` secret reference, then run commands through `op run`.
# `.env` is gitignored.
#
# Rule: new token goes into 1Password first, then the copied op:// reference
# goes into `.env`. No plaintext token belongs in this repo.
#
# For repeated local ops, inject from `.env` into app-local `.env.local` files.
# Those generated files contain plaintext secrets and are also gitignored.

# Web runtime
PUBLIC_DIRECTUS_URL=https://cms.yesid.dev
DIRECTUS_READ_TOKEN=op://yesid-dev/<directus-read-token-item>/credential
OPENWEATHER_API_KEY=op://yesid-dev/<openweather-item>/credential
WEB3FORMS_ACCESS_KEY=op://yesid-dev/<web3forms-item>/credential
VITE_WEB3FORMS_ACCESS_KEY=op://yesid-dev/<web3forms-item>/credential

# Directus admin ops
DIRECTUS_URL=https://cms.yesid.dev
DIRECTUS_ADMIN_EMAIL=op://yesid-dev/<directus-admin-item>/username
DIRECTUS_ADMIN_PASSWORD=op://yesid-dev/<directus-admin-item>/password

# Directus sync-push production guardrails.
# Uncomment only for an intentional production schema push.
# DIRECTUS_SYNC_ALLOW_PROD_SCHEMA_PUSH=1
# DIRECTUS_SYNC_PUSH_ACK=sync-push-can-delete-cms-data
