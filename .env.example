# Project secrets manifest
#
# This file documents every secret the project reads at runtime.
# Real values live in 1Password; inject them via `op run --env-file=.env -- <cmd>`.
#
# Usage:
#   cp .env.example .env
#   op run --env-file=.env -- <your command>
#
# Convention: op://<vault-name>/<item-title>/credential
# - Item titles are lowercase slugs (e.g., openweather, resend).
# - Field name is `credential` (1Password default for API Credential category).
# - URLs live in the native item URL field (not referenced here).
#
# Full inventory for this project: docs/reference/secrets-inventory.md (fill in)

# --- Runtime secrets (required in 1Password) ---

# Directus admin email + password. Used by scripts/seed-directus-services.ts
# (Slice 18 Task 6) to authenticate against cms.yesid.dev and upsert content.
# Short-lived access token retrieved via POST /auth/login; never stored.
# NOTE: the site's runtime adapter does NOT need a token — it reads
# anonymously via the Public policy (see src/lib/adapters/directus.ts).
DIRECTUS_ADMIN_EMAIL=op://yesid-dev/thkyjj4lpbpkvdzm3tbkcltj6u/username
DIRECTUS_ADMIN_PASSWORD=op://yesid-dev/thkyjj4lpbpkvdzm3tbkcltj6u/password

# <!-- FILL IN: replace these placeholders with real secrets this project uses. -->
# EXAMPLE_API_KEY=op://<your-vault>/<service-name>/credential
# EXAMPLE_DATABASE_URL=op://<your-vault>/<service-name>/credential

# --- Non-secret env vars (not managed via 1Password) ---
# Set in shell, CI config, or a local override.
#
# Directus base URL. PUBLIC_ prefix = safe to reach from client bundle
# (SvelteKit $env/static/public contract). Defaults to production CMS in
# prod; set to http://localhost:8055 for local Directus dev.
PUBLIC_DIRECTUS_URL=https://cms.yesid.dev

