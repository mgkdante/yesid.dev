# --- Postgres (Neon) ---
# Local dev: pooled connection string to a Neon dev branch (created via Neon console).
# Vercel prod: auto-set by the Neon Vercel Marketplace integration (both DATABASE_URL + DATABASE_URL_UNPOOLED).
# Payload reads DATABASE_URI first and falls back to DATABASE_URL.
DATABASE_URI=postgresql://user:password@ep-xxxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Payload ---
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace-me-32-chars-min

# Public URL where Payload serves its admin + API. Local dev = localhost:3000; prod = https://cms.yesid.dev.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Storage (Vercel Blob) ---
# Auto-set by the Vercel Blob integration once a Blob store is provisioned.
# Leave empty in local dev — uploads fall back to the local filesystem (and Blob plugin disables itself).
BLOB_READ_WRITE_TOKEN=

# --- Email (Resend) ---
# Get from resend.com/api-keys. Leave empty in local dev — Payload logs emails to console.
RESEND_API_KEY=

# --- Admin bootstrap (remove after first login per Slice 18a spec D6) ---
# onInit hook creates an admin user from these vars if the users table has no admin.
# After first successful login, rotate the password via admin UI and DELETE these two vars from Vercel env.
PAYLOAD_ADMIN_EMAIL=
PAYLOAD_ADMIN_PASSWORD=
