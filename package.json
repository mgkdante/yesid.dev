{
	"name": "yesid-dev",
	"private": true,
	"type": "module",
	"description": "yesid.dev monorepo - apps/web (SvelteKit consumer) + apps/cms (Directus config). Workflow contract: AGENTS.md; long-form context lives in Notion.",
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "cd apps/web && bun run dev",
		"dev:op": "op run --env-file=.env -- bun run dev",
		"dev:local-env": "bun --env-file=apps/web/.env.local run dev",
		"build": "turbo run build",
		"build:op": "op run --env-file=.env -- bun run --cwd apps/cms export:fallbacks && EXPORT_FALLBACKS_SKIP=1 turbo run build",
		"test": "turbo run test",
		"check": "turbo run check",
		"cms:sync:diff:op": "op run --env-file=.env -- bun run --cwd apps/cms sync:diff",
		"cms:sync:push:op": "op run --env-file=.env -- bun run --cwd apps/cms sync:push",
		"cms:sync:diff:local-env": "bun run --env-file=apps/cms/.env.local --cwd apps/cms sync:diff",
		"secrets:inject:web": "op inject -i .env -o apps/web/.env.local",
		"secrets:inject:cms": "op inject -i .env -o apps/cms/.env.local",
		"secrets:whoami": "op whoami",
		"secrets:ratelimit": "op service-account ratelimit",
		"tokens:build": "bun run --cwd apps/web tokens:build",
		"tokens:check": "bun run --cwd apps/web tokens:check",
		"tokens:lint": "design.md lint DESIGN.md",
		"ci:tokens": "bun run tokens:check && bun run tokens:lint",
		"ci:content": "bun run --cwd apps/cms verify:content",
		"setup:hooks": "git config core.hooksPath .githooks"
	},
	"devDependencies": {
		"@google/design.md": "0.1.1",
		"@yesid/config": "https://github.com/mgkdante/yesid.dev-design/releases/download/config-v0.2.0/yesid-config-v0.2.0.tgz",
		"turbo": "^2.5.0"
	},
	"overrides": {
		"satori": "0.10.14"
	},
	"engines": {
		"bun": ">=1.3.0",
		"node": ">=22.0.0"
	}
}
