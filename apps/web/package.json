{
	"name": "@repo/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "bun ../../apps/cms/scripts/export-fallbacks.ts",
		"build": "vite build && bun run check:sitemap",
		"check:sitemap": "vitest run src/tests/sitemap-coverage.test.ts",
		"og:default": "bun scripts/generate-og-default.ts",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"bundle-size": "bun run build && echo 'Bundle stats at dist/stats.html'",
		"brand:export-logos": "bun ../../brand/scripts/export-logos.ts",
		"brand:export-examples": "bun ../../brand/scripts/export-examples.ts",
		"slice:close:legacy": "bun scripts/slice-close.ts",
		"seed:services": "op run --env-file=.env -- bun scripts/seed-directus-services.ts"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.4.0",
		"@gltf-transform/core": "^4.3.0",
		"@gltf-transform/extensions": "^4.3.0",
		"@gltf-transform/functions": "^4.3.0",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.8.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-vercel": "^6.3.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/table-core": "^8.21.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@vitest/coverage-v8": "^4.1.5",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"formsnap": "^2.0.1",
		"happy-dom": "^20.8.9",
		"interface-forge": "^2.6.6",
		"jsdom": "^29.0.1",
		"layerchart": "2.0.0-next.48",
		"meshoptimizer": "^1.1.0",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"rollup-plugin-visualizer": "^7.0.1",
		"sharp": "^0.34.5",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.0",
		"svgo": "^4.0.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@directus/sdk": "^20",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@iconify/svelte": "^5.2.1",
		"@repo/shared": "workspace:*",
		"@resvg/resvg-js": "^2.6.2",
		"embla-carousel": "^8.6.0",
		"embla-carousel-wheel-gestures": "^8.1.0",
		"gsap": "^3.14.2",
		"lenis": "^1.3.21",
		"marked": "^17.0.6",
		"mdsvex": "^0.12.7",
		"p-queue": "^9.1.2",
		"satori": "^0.10.13",
		"shiki": "^4.0.2",
		"zod": "^4.3.6"
	}
}
