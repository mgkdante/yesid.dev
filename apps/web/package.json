{
	"name": "@repo/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "bun ../../apps/cms/scripts/export-fallbacks.ts",
		"build": "vite build && bun run check:sitemap",
		"check:sitemap": "vitest run src/tests/sitemap-coverage.test.ts",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"bundle-size": "bun run build && echo 'Bundle stats at dist/stats.html'",
		"check:engine-chunk": "node scripts/check-engine-chunk.mjs"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.4.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-vercel": "^6.3.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"happy-dom": "^20.8.9",
		"interface-forge": "^2.6.6",
		"paneforge": "^1.0.2",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"svgo": "^4.0.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@repo/shared": "workspace:*",
		"@resvg/resvg-js": "^2.6.2",
		"embla-carousel": "^8.6.0",
		"embla-carousel-wheel-gestures": "^8.1.0",
		"gsap": "^3.14.2",
		"lenis": "^1.3.21",
		"marked": "^18.0.2",
		"satori": "^0.10.13",
		"shiki": "^4.0.2",
		"zod": "^4.3.6"
	}
}
