# apps/web env manifest (post-slice-27.2)
#
# Real values live in 1Password; inject via `op run --env-file=.env -- <cmd>`
# or materialize a gitignored .env.local with `bun run secrets:inject:web`
# (root package.json). Convention: op://<vault>/<item>/<field>.
#
# Architecture note (slice-27.2): the deployed site reads all *data* from the
# build-time static content layer. Directus credentials below are BUILD/TEST
# concerns only — the one live runtime CMS seam is asset URLs composed from
# PUBLIC_DIRECTUS_URL (see "MEDIA RUNTIME SEAM" in packages/shared/src/assets.ts).

# --- Runtime ----------------------------------------------------------------

# Directus base URL. PUBLIC_ prefix = exposed to the client bundle (SvelteKit
# $env contract). At runtime this is ONLY used to compose /assets/<uuid> media
# URLs ($lib/directus/assets.ts — throws into SSR if unset). Defaults:
#   • Production:           https://cms.yesid.dev
#   • Dev CMS (canonical):  https://cms.dev.yesid.dev
#   • Dev CMS (direct):     https://directus-cms-dev-production.up.railway.app
#   • Local Directus:       http://localhost:8055
PUBLIC_DIRECTUS_URL=https://cms.yesid.dev

# OpenWeatherMap API key for the About-page weather widget (/api/weather,
# server-side only). The existing credential must be independently scoped to
# Vercel Production and protected develop Preview; generic Preview gets none.
OPENWEATHER_API_KEY=op://yesid-dev/som5o63cwaogtv3gwgc5qar7ye/credential

# Contact form: the Web3Forms access key is NOT an env var — it ships as CMS
# content (block_contact_content.web3forms_key) through the static layer.

# --- Build-time (prebuild: apps/cms/scripts/export-fallbacks.ts) -------------
#
# The prebuild exports CMS content into the static content layer. Auth
# routing (see apps/cms/scripts/lib/auth.ts):
#   1. Production: DIRECTUS_BUILD_TOKEN, pinned to cms.yesid.dev.
#   2. develop Preview: DIRECTUS_DEV_BUILD_TOKEN, pinned to cms.dev.yesid.dev.
#   3. Local: DIRECTUS_ADMIN_TOKEN, then email/password login fallback.
# Generic Preview skips before auth even if EXPORT_FALLBACKS_LIVE is mis-scoped.
# Missing auth on either trusted live target fails loud; local runs retain the
# soft cache/committed-content fallback.
# EXPORT_FALLBACKS_SKIP=1 skips the export entirely (committed content modules
# stay authoritative) — used by CI for hermetic builds (slice-28.4, web.yml).
# DIRECTUS_BUILD_TOKEN=  # Vercel env vars only — never commit tokens
# DIRECTUS_DEV_BUILD_TOKEN=  # develop-branch Preview only — never generic Preview
DIRECTUS_ADMIN_EMAIL=op://yesid-dev/thkyjj4lpbpkvdzm3tbkcltj6u/username
DIRECTUS_ADMIN_PASSWORD=op://yesid-dev/thkyjj4lpbpkvdzm3tbkcltj6u/password

# --- Test-only ----------------------------------------------------------------
#
# RUN_DIRECTUS_INTEGRATION=1 gates the dormant-adapter integration suite
# (src/lib/adapters/directus.integration.test.ts) — the RUN_PARITY oracle for
# the slice-26 Directus v12 upgrade. CI sets it in contract-test.yml against
# an ephemeral Directus; unset locally, the suite self-skips.
# RUN_DIRECTUS_INTEGRATION=1
