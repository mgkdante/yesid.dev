# Project secrets manifest
#
# This file documents every secret the project reads at runtime.
# Real values live in 1Password; inject them via `op run --env-file=.env -- <cmd>`.
#
# Usage:
#   cp .env.example .env
#   op run --env-file=.env -- <your command>
#
# Convention: op://<vault-name>/<item-title>/credential
# - Item titles are lowercase slugs (e.g., openweather, resend).
# - Field name is `credential` (1Password default for API Credential category).
# - URLs live in the native item URL field (not referenced here).
#
# Full inventory for this project: docs/reference/secrets-inventory.md (fill in)

# --- Runtime secrets (required in 1Password) ---

# Directus admin email + password. Used by scripts/seed-directus-services.ts
# (Slice 18 Task 6) to authenticate against cms.yesid.dev and upsert content.
# Short-lived access token retrieved via POST /auth/login; never stored.
# NOTE: the site's runtime adapter does NOT need a token — it reads
# anonymously via the Public policy (see src/lib/adapters/directus.ts).
DIRECTUS_ADMIN_EMAIL=op://yesid-dev/thkyjj4lpbpkvdzm3tbkcltj6u/username
DIRECTUS_ADMIN_PASSWORD=op://yesid-dev/thkyjj4lpbpkvdzm3tbkcltj6u/password

# <!-- FILL IN: replace these placeholders with real secrets this project uses. -->
# EXAMPLE_API_KEY=op://<your-vault>/<service-name>/credential
# EXAMPLE_DATABASE_URL=op://<your-vault>/<service-name>/credential

# Directus read-scoped token for SSR load()s. PUBLIC_ prefix is intentionally
# NOT used — this token is server-side only (SvelteKit $env/static/private).
# Create via Data Studio → admin user → Token. Scope: read-only on user
# collections (languages + services + future projects/blog/tech-stack).
# Alternative: leave unset + rely on Public policy reads (anonymous).
DIRECTUS_READ_TOKEN=op://yesid-dev/<item>/credential

# OpenWeatherMap API key for the About page weather widget.
OPENWEATHER_API_KEY=op://yesid-dev/som5o63cwaogtv3gwgc5qar7ye/credential

# Web3Forms access key for contact form endpoint.
# WEB3FORMS_* server-side, VITE_WEB3FORMS_* client-side (both needed — Vite
# inlines only VITE_-prefixed at build time).
WEB3FORMS_ACCESS_KEY=op://yesid-dev/actdudlx5g54zr3ndpwnv7y7x4/credential
VITE_WEB3FORMS_ACCESS_KEY=op://yesid-dev/actdudlx5g54zr3ndpwnv7y7x4/credential

# --- Non-secret env vars (not managed via 1Password) ---
# Set in shell, CI config, or a local override.
#
# Directus base URL. PUBLIC_ prefix = safe to reach from client bundle
# (SvelteKit $env/static/public contract). Defaults to production CMS in
# prod; set to http://localhost:8055 for local Directus dev.
PUBLIC_DIRECTUS_URL=https://cms.yesid.dev

# --- Post-Slice-18 preview routes (F22 web side; 18c Task 37 reservation) -----
#
# Vercel Protection Bypass token — lets the `/api/revalidate` route accept
# invalidation webhooks from Directus Flow Event Hooks (D8 full-site
# revalidation). Generate via Vercel Project → Settings → Deployment
# Protection → Protection Bypass → Add Token. Server-side only (no VITE_
# prefix).
# VERCEL_BYPASS_TOKEN=op://yesid-dev/<item>/credential

# --- CSP notes (F22 — referenced here; enforced at the hosting layer) ----------
#
# Directus side (apps/cms/.env.example) sets
# CONTENT_SECURITY_POLICY_DIRECTIVES__FRAME_SRC covering Visual Editor
# iframes. apps/web CSP headers are configured in svelte.config.js or a
# Vercel vercel.json security headers block — populate when preview routes
# land post-Slice-18.
