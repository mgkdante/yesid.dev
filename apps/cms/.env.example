# =============================================================================
# TWO USE CASES FOR THIS FILE
# =============================================================================
#
# 1. RAILWAY DASHBOARD provisioning (paste blocks into Project → Variables):
#    Use the body of this file as a literal reference. Real secrets entered
#    by hand in Railway UI; this file is the schema/comments.
#
# 2. LOCAL OPS INJECT (apps/cms/.env, gitignored):
#    Sub-set of vars needed by sync:diff / sync:push / seed:* scripts.
#    Use op:// references that resolve at runtime via `op run`.
#
#    Recipe (DEV — default for everyday ops + refresh orchestrator):
#      DIRECTUS_URL=https://cms.dev.yesid.dev
#      PUBLIC_DIRECTUS_URL=https://cms.dev.yesid.dev
#      DIRECTUS_ADMIN_EMAIL=op://yesid-dev/Directus admin - cms.dev.yesid.dev/username
#      DIRECTUS_ADMIN_PASSWORD=op://yesid-dev/Directus admin - cms.dev.yesid.dev/password
#      NEON_API_KEY=op://yesid-dev/Neon API key - yesid/credential
#      STORAGE_S3_KEY=op://yesid-dev/Cloudflare R2 - yesid.dev-cms/Access Key ID
#      STORAGE_S3_SECRET=op://yesid-dev/Cloudflare R2 - yesid.dev-cms/Secret Access Key
#      STORAGE_S3_ENDPOINT=https://eccfb9bedd87d413eaf4cac6ae2285d3.r2.cloudflarestorage.com
#      # then for normal ops:
#      #   op run --env-file=apps/cms/.env -- bun --cwd apps/cms run sync:diff
#      # for full dev-from-prod refresh:
#      #   op run --env-file=apps/cms/.env -- bash apps/cms/scripts/refresh-dev-from-prod.sh
#
#    Recipe (PROD — override inline; sync-push.ts requires explicit acks):
#      DIRECTUS_URL=https://cms.yesid.dev \
#      DIRECTUS_ADMIN_EMAIL=op://yesid-dev/Directus admin - cms.yesid.dev/username \
#      DIRECTUS_ADMIN_PASSWORD=op://yesid-dev/Directus admin - cms.yesid.dev/password \
#      DIRECTUS_SYNC_ALLOW_PROD_SCHEMA_PUSH=1 \
#      DIRECTUS_SYNC_PUSH_ACK=sync-push-can-delete-cms-data \
#      op run --env-file=apps/cms/.env -- bun --cwd apps/cms run sync:push
#
# =============================================================================
# yesid.dev-cms — Directus environment variables (Railway dashboard reference)
# =============================================================================
#
# Copy to `.env` locally; paste each block into Railway Dashboard → Variables in prod.
# Never commit a filled .env — it's gitignored.
#
# Spec: Notion slice-18 page (Slices DB).
# Target version: directus/directus:11.17.3 (pin; don't float `latest`).

# --- Directus core (required) ----------------------------------------------

# Secrets — generate once per environment, never rotate casually.
#   KEY:    openssl rand -hex 16   (16-byte hex, used for internal JWT signing)
#   SECRET: openssl rand -hex 32   (32-byte hex, used for access-token signing)
KEY=
SECRET=

# Public URL — where Directus serves its admin + API. Set to the final URL once
# DNS flips; during Railway provisioning use the temporary Railway domain.
PUBLIC_URL=https://cms.yesid.dev

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# --- Admin bootstrap (delete after first successful login) -----------------
#
# On first boot with an empty `directus_users` table, Directus creates one
# admin from these vars. Rotate the password via the admin UI immediately,
# then DELETE both vars from Railway — they're a bootstrap, not a standing
# credential.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Database (Neon Postgres — BYO, preserved across migration) ------------
#
# Use the POOLED connection string from Neon for Directus (unpooled is for
# scripts / migrations; Directus handles its own connection pool).
# Format: postgres://user:pass@ep-xxxx-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DB_CLIENT=pg
DB_CONNECTION_STRING=
DB_SSL__REJECT_UNAUTHORIZED=true

# --- Storage (Cloudflare R2 via built-in s3 driver) ------------------------
#
# R2 credentials from Cloudflare Dashboard → R2 → Manage API Tokens.
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com (no bucket in URL).
# Region: always `auto` for R2.
# Force path style: required for R2 (bucket comes after endpoint, not as subdomain).
STORAGE_LOCATIONS=s3
STORAGE_S3_DRIVER=s3
STORAGE_S3_KEY=
STORAGE_S3_SECRET=
STORAGE_S3_BUCKET=yesid-dev-cms
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=auto
STORAGE_S3_FORCE_PATH_STYLE=true

# --- Cache (Redis — improves API throughput; Railway template provisions) --
#
# If Railway template includes a Redis plugin, CACHE_REDIS is auto-injected.
# Otherwise set manually or disable (CACHE_ENABLED=false).
CACHE_ENABLED=true
CACHE_STORE=redis
CACHE_REDIS=
CACHE_AUTO_PURGE=true
CACHE_TTL=5m

# --- Email (Resend via SMTP — DKIM + SPF already set on domain) ------------
#
# Resend API key from resend.com/api-keys — use the SAME key the prior Payload
# install used (already configured). SMTP user is literally the string "resend".
EMAIL_FROM=no-reply@yesid.dev
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=smtp.resend.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=resend
EMAIL_SMTP_PASSWORD=

# --- CORS (allow yesid.dev consumer + Vercel preview deployments) ----------
CORS_ENABLED=true
CORS_ORIGIN=https://yesid.dev,https://*.vercel.app
CORS_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_CREDENTIALS=true

# --- Rate limiter (Q12 — conservative instance-wide — Railway deploy target) ----
#
# Directus rate limiter is instance-level (no per-role support as of 11.17).
# Settings below match F16 + F22 Q12 conservative defaults for a low-traffic
# portfolio site. Bump if analytics show sustained throttle.
RATE_LIMITER_ENABLED=true
RATE_LIMITER_STORE=memory
RATE_LIMITER_POINTS=50
RATE_LIMITER_DURATION=1
RATE_LIMITER_HEALTHCHECK=false

# --- Asset transforms (D9 — presets locked, no on-the-fly transforms) ----------
#
# 'presets' means Directus rejects ?width=XXX&height=YYY on /assets — consumers
# MUST request a named preset via ?key=hero-1200 etc. Tighter cache keys,
# cheaper R2 bill, no enumeration of content via request crafting.
# Presets themselves are authored in Directus Data Studio → Settings → Files.
STORAGE_ASSET_TRANSFORM=presets

# --- Revisions retention (F18 — 90d content versioning window) -----------------
#
# Directus writes a directus_revisions row on every item update (Content
# Versioning + Global Draft need this). 90d keeps enough history for
# rollback while bounding table growth.
REVISIONS_RETENTION=90d

# --- Realtime (F16 — WebSockets + collaborative editing for Data Studio) ------
WEBSOCKETS_ENABLED=true
WEBSOCKETS_COLLAB_ENABLED=true

# --- CSP FRAME_SRC (F22 — Visual Editor + preview iframe support) --------------
#
# Directus Data Studio's Visual Editing + Preview features iframe the consumer
# site. Allow yesid.dev (prod) + Vercel previews.
CONTENT_SECURITY_POLICY_DIRECTIVES__FRAME_SRC=https://yesid.dev https://*.vercel.app

# --- MCP server (native since v11.13 — GA Nov 2025) ------------------------
#
# Enables the /mcp endpoint. Create a dedicated `ai-editor` role in Directus
# and issue it a static access token for Claude Code / Desktop / other MCP clients.
# Role scope: content collections only — NOT directus_users, directus_settings, etc.
#
# MCP_ALLOW_DELETES=false is set at the settings-row level (not an env var);
# see apps/cms/directus/collections/settings.json mcp_allow_deletes field.
MCP_ENABLED=true

# --- Build Bot token (Vercel production builds) ----------------------------
#
# Read-only static token used by apps/cms/scripts/export-fallbacks.ts when
# VERCEL_ENV=production. Preferred over DIRECTUS_ADMIN_TOKEN for builds so
# the build identity has the minimum required permissions.
#
# Operator step to mint the token:
#   1. In Directus Data Studio → Settings → Access Policies, create a new
#      policy named "Build Bot" with READ-ONLY access on ALL content
#      collections (site_meta, nav, services, projects, blog_posts,
#      route_seo, error_pages, morph_shapes, tech_stack, block_* singletons).
#   2. Create a new system user (e.g. "build-bot@yesid.dev") and assign it
#      the "Build Bot" policy.
#   3. Generate a static token for that user (Settings → Users → build-bot →
#      Token field). Copy the token.
#   4. In Vercel Dashboard → Project → Settings → Environment Variables, add:
#        DIRECTUS_BUILD_TOKEN = <token>  (Production environment only, encrypted)
#
# The export-fallbacks.ts prefers DIRECTUS_BUILD_TOKEN over DIRECTUS_ADMIN_TOKEN.
# In production, a missing token causes an immediate exit 1 (loud failure).
# In local/preview, the existing DIRECTUS_ADMIN_TOKEN / email+password flow continues.
#
# DIRECTUS_BUILD_TOKEN=  # set in Vercel env vars, NOT here (never commit tokens)
