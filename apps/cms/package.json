{
	"name": "@repo/cms",
	"private": true,
	"type": "module",
	"description": "Config + snapshot + seed scripts for the Directus CMS backing yesid.dev. The Directus app itself runs from the pinned directus/directus:12.0.0 container on Railway — this repo ships schema, seed data, and ops tooling only.",
	"scripts": {
		"seed:services": "bun scripts/seed-services.ts",
		"export:fallbacks": "bun scripts/export-fallbacks.ts",
		"verify:content": "bun scripts/verify-content-manifest.ts",
		"seed:projects": "bun scripts/seed-projects.ts",
		"seed:presets": "bun scripts/seed-presets.ts",
		"seed:icons": "bun scripts/seed-icons.ts",
		"seed:brand-assets": "bun scripts/seed-brand-assets.ts",
		"seed:pages": "bun scripts/seed-pages-and-blocks.ts",
		"fixtures:refresh": "bun scripts/refresh-fixtures.ts",
		"archive:lorem": "bun scripts/archive-lorem-posts.ts",
		"setup:archetypes": "bun scripts/setup-stack-archetypes-schema.ts",
		"setup:flat-fields": "bun scripts/setup-block-flat-fields.ts",
		"migrate:flat-fields": "bun scripts/migrate-block-json-to-flat.ts",
		"setup:site-labels": "bun scripts/setup-site-labels-and-chrome.ts",
		"content:terminus-routes": "bun scripts/content-terminus-routes.ts",
		"seed:archetypes": "bun scripts/seed-stack-archetypes.ts",
		"migrate:assets": "bun scripts/migrate-assets.ts",
		"sync:pull": "directus-sync pull",
		"sync:push": "bun scripts/sync-push.ts",
		"sync:diff": "directus-sync diff",
		"test": "bun test"
	},
	"devDependencies": {
		"@aws-sdk/client-s3": "^3.1039.0",
		"@directus/sdk": "^20.3.0",
		"@repo/shared": "workspace:*",
		"bottleneck": "^2.19.5",
		"bun-types": "latest",
		"directus-sync": "^3.5.0",
		"marked": "^18.0.2",
		"sharp": "^0.35.3",
		"zod": "^4.3.6"
	}
}
