{
	"extends": "@yesid/config/tsconfig/library.json",
	"compilerOptions": {
		"module": "ESNext",
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false,
		"types": ["bun-types"],
		"lib": ["ES2022"]
	},
	"include": ["scripts/**/*", "tests/**/*", "fixtures/**/*"]
}
