{
  "$schema": "https://design-tokens.github.io/community-group/format/draft.json",
  "$description": "yesid.dev design tokens (DTCG). Source of truth — generators in build.ts produce all other token surfaces.",
  "color": {
    "brand": {
      "primary": { "$type": "color", "$value": "#E07800", "$description": "Single interactive brand hue. Buttons, links, focus rings, the orange dot in 'yesid.' Light theme overrides to #A65600 for AA; dark re-pins #E07800 so .theme-dark scene pinning survives inside light pages." },
      "primary-hover": { "$type": "color", "$value": "#C96A00" },
      "accent": { "$type": "color", "$value": "#FFB627", "$description": "Selection highlights, hazard tape, art fills. NEVER body text — use accent-text." },
      "accent-hover": { "$type": "color", "$value": "#E5A220" },
      "primary-rgb": { "$type": "string", "$value": "224 120 0", "$description": "RGB channels for rgb(var(--primary-rgb) / alpha) usage." },
      "destructive-foreground": { "$type": "color", "$value": "#FAFAF8", "$description": "Text color on destructive/error backgrounds." }
    },
    "dark": {
      "background": { "$type": "color", "$value": "#141414" },
      "foreground": { "$type": "color", "$value": "#F5F5F0" },
      "muted": { "$type": "color", "$value": "#1E1E1E" },
      "muted-foreground": { "$type": "color", "$value": "#949494", "$description": "GO-W2.2: was #666666 (3.21:1, failed AA everywhere). 4.73:1 worst-case on popover." },
      "card": { "$type": "color", "$value": "#1a1a1a" },
      "popover": { "$type": "color", "$value": "#2A2A2A" },
      "secondary-foreground": { "$type": "color", "$value": "#999999" },
      "terminal": { "$type": "color", "$value": "#0a0a0a" },
      "manifesto": { "$type": "color", "$value": "#0f0d0a" },
      "border": { "$type": "color", "$value": "#3A3A3A" },
      "border-subtle": { "$type": "color", "$value": "#2f2f2f", "$description": "GO-W2.2: was #2a2a2a (invisible on card surfaces, 1.21:1)." },
      "border-strong": { "$type": "color", "$value": "#4A4A4A", "$description": "GO-W2.2: was #333333 — 'strong' sat BELOW default. Scale is now subtle < default < strong." },
      "destructive": { "$type": "color", "$value": "#ff5f57" },
      "success": { "$type": "color", "$value": "#28c840" },
      "primary": { "$type": "color", "$value": "#E07800", "$description": "Re-pin for .theme-dark subtrees inside light pages." },
      "primary-hover": { "$type": "color", "$value": "#C96A00" },
      "primary-rgb": { "$type": "string", "$value": "224 120 0" },
      "accent-text": { "$type": "color", "$value": "#FFB627", "$description": "Accent when used AS text. Identical to --accent in dark; darkened in light." },
      "accent-foreground": { "$type": "color", "$value": "#141414", "$description": "Text on accent surfaces (explicit; overrides the paired alias)." },
      "input": { "$type": "color", "$value": "#3A3A3A", "$description": "Form-control boundary (explicit; equals --border in dark)." }
    },
    "light": {
      "background": { "$type": "color", "$value": "#FAFAF8" },
      "foreground": { "$type": "color", "$value": "#111111" },
      "muted": { "$type": "color", "$value": "#F0EDE5" },
      "muted-foreground": { "$type": "color", "$value": "#6F6F6F", "$description": "GO-W2.2: was #888888 (3.39:1 on bg). 4.81:1 bg / 5.02:1 card." },
      "card": { "$type": "color", "$value": "#FFFFFF" },
      "popover": { "$type": "color", "$value": "#FFFFFF" },
      "secondary-foreground": { "$type": "color", "$value": "#555555" },
      "terminal": { "$type": "color", "$value": "#F5F5F0" },
      "manifesto": { "$type": "color", "$value": "#F0EDE5" },
      "border": { "$type": "color", "$value": "#D8D4CA" },
      "border-subtle": { "$type": "color", "$value": "#D8D4CA" },
      "border-strong": { "$type": "color", "$value": "#C0BDB5" },
      "destructive": { "$type": "color", "$value": "#C62828", "$description": "GO-W2.2: was #ff5f57 (2.86:1 on paper). 5.38:1." },
      "success": { "$type": "color", "$value": "#15803D", "$description": "GO-W2.2: was #16a34a (~3.15:1). 4.80:1." },
      "primary": { "$type": "color", "$value": "#A65600", "$description": "AA interactive orange on paper: 5.08:1 bg / 5.31:1 card. Same hue family as #E07800 (R/G 1.93)." },
      "primary-hover": { "$type": "color", "$value": "#8F4A00" },
      "primary-rgb": { "$type": "string", "$value": "166 86 0" },
      "accent-text": { "$type": "color", "$value": "#8A6400", "$description": "Amber ink — accent-as-text on paper, 5.1:1." },
      "accent-foreground": { "$type": "color", "$value": "#111111", "$description": "Was var(--background)=#FAFAF8 on #FFB627 = 1.68:1. Now 11.97:1." },
      "input": { "$type": "color", "$value": "#949083", "$description": "3.06:1 form boundary (WCAG 1.4.11); decorative --border stays lighter." }
    }
  },
  "font": {
    "heading": { "$type": "fontFamily", "$value": "'Inter Variable', 'Inter', system-ui, -apple-system, sans-serif" },
    "body": { "$type": "fontFamily", "$value": "'Inter Variable', 'Inter', system-ui, -apple-system, sans-serif" },
    "mono": { "$type": "fontFamily", "$value": "'JetBrains Mono Variable', 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace" }
  },
  "text": {
    "hero": { "$type": "yesid.clamp", "$value": { "min": "4rem", "preferred": "min(9vw, 11svh)", "max": "8.125rem" }, "$description": "HeroBanner wordmark only." },
    "hero-mobile": { "$type": "yesid.clamp", "$value": { "min": "3rem", "preferred": "min(13vw, 8svh)", "max": "4rem" } },
    "display": { "$type": "yesid.clamp", "$value": { "min": "2.5rem", "preferred": "5vw", "max": "4rem" } },
    "title": { "$type": "yesid.clamp", "$value": { "min": "1.75rem", "preferred": "4vw", "max": "2.5rem" } },
    "heading": { "$type": "yesid.clamp", "$value": { "min": "1.25rem", "preferred": "3vw", "max": "1.5rem" } },
    "subheading": { "$type": "dimension", "$value": "1.125rem" },
    "body": { "$type": "dimension", "$value": "1rem" },
    "small": { "$type": "dimension", "$value": "0.875rem" },
    "mono": { "$type": "dimension", "$value": "0.8125rem" },
    "caption": { "$type": "dimension", "$value": "0.75rem" },
    "micro": { "$type": "dimension", "$value": "0.625rem" }
  },
  "space": {
    "page-x": { "$type": "yesid.clamp", "$value": { "min": "1.5rem", "preferred": "4vw", "max": "5rem" } },
    "section-y": { "$type": "yesid.clamp", "$value": { "min": "3rem", "preferred": "8vw", "max": "6rem" } },
    "card-gap": { "$type": "yesid.clamp", "$value": { "min": "1rem", "preferred": "2vw", "max": "1.5rem" } }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "8px" },
    "lg": { "$type": "dimension", "$value": "12px" },
    "xl": { "$type": "dimension", "$value": "16px" },
    "pill": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "glow-sm": { "$type": "string", "$value": "0 0 6px color-mix(in srgb, var(--primary) 30%, transparent)" },
    "glow-md": { "$type": "string", "$value": "0 0 12px color-mix(in srgb, var(--primary) 20%, transparent)" },
    "glow-lg": { "$type": "string", "$value": "0 0 24px color-mix(in srgb, var(--primary) 15%, transparent), 0 0 60px color-mix(in srgb, var(--primary) 6%, transparent)" },
    "card": { "$type": "string", "$value": "0 0 16px color-mix(in srgb, var(--primary) 8%, transparent), 0 2px 8px rgba(0, 0, 0, 0.3)" },
    "section": { "$type": "string", "$value": "0 8px 32px color-mix(in srgb, var(--primary) 6%, transparent)" },
    "nav": { "$type": "string", "$value": "0 4px 30px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.03)" },
    "sheet": { "$type": "string", "$value": "0 -8px 32px rgb(0 0 0 / 0.4)", "$description": "GO-W2.2: formalizes the TocPill bottom-sheet shadow." }
  },
  "surface": {
    "$description": "GO-W2.2 luminance-ordered surface scale. Pure var() aliases — zero drift, theme-switching flows through. 0=terminal/code, 1=page+canonical card, 2=inputs/sheets, 3=side panels, 4=elevated chips, hero=manifesto/detail heroes.",
    "0": { "$type": "string", "$value": "var(--terminal)" },
    "1": { "$type": "string", "$value": "var(--background)" },
    "2": { "$type": "string", "$value": "var(--card)" },
    "3": { "$type": "string", "$value": "var(--muted)" },
    "4": { "$type": "string", "$value": "var(--popover)" },
    "hero": { "$type": "string", "$value": "var(--manifesto)" }
  },
  "border": {
    "$description": "GO-W2.2 brand-border + hairline aliases. The Constitution Section 13 card spec, defined ONCE.",
    "brand": { "$type": "string", "$value": "color-mix(in srgb, var(--primary) 25%, transparent)" },
    "brand-active": { "$type": "string", "$value": "color-mix(in srgb, var(--primary) 60%, transparent)" },
    "hairline": { "$type": "string", "$value": "color-mix(in srgb, var(--foreground) 8%, transparent)" }
  },
  "z": {
    "base": { "$type": "number", "$value": 0 },
    "content": { "$type": "number", "$value": 1 },
    "rail": { "$type": "number", "$value": 30 },
    "sheet": { "$type": "number", "$value": 50 },
    "menu": { "$type": "number", "$value": 60 },
    "nav": { "$type": "number", "$value": 70 }
  },
  "duration": {
    "instant": { "$type": "duration", "$value": "100ms" },
    "fast": { "$type": "duration", "$value": "150ms" },
    "normal": { "$type": "duration", "$value": "200ms" },
    "slow": { "$type": "duration", "$value": "300ms" },
    "slower": { "$type": "duration", "$value": "500ms" }
  },
  "ease": {
    "default": { "$type": "cubicBezier", "$value": "cubic-bezier(0.4, 0, 0.2, 1)" },
    "out": { "$type": "cubicBezier", "$value": "cubic-bezier(0.2, 0.8, 0.2, 1)" },
    "in-out": { "$type": "cubicBezier", "$value": "cubic-bezier(0.4, 0, 0.2, 1)" },
    "bounce": { "$type": "cubicBezier", "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)" }
  },
  "opacity": {
    "muted": { "$type": "number", "$value": 0.6 },
    "dim": { "$type": "number", "$value": 0.3 },
    "subtle": { "$type": "number", "$value": 0.15 },
    "faint": { "$type": "number", "$value": 0.05 }
  },
  "container": {
    "content": { "$type": "dimension", "$value": "64rem" },
    "wide": { "$type": "dimension", "$value": "72rem" }
  }
}
